{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Screen Guardian",
  "version": "0.2.0",
  "identifier": "com.screen-guardian.app",
  "build": {
    "frontendDist": "./ui"
  },
  "app": {
    "windows": [
      {
        "title": "屏幕守护者 v0.2.0",
        "width": 960,
        "height": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
